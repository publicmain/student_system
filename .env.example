# ─────────────────────────────────────────────────────────
#  学生升学管理系统 — 环境变量模板
#  复制为 .env 并填写实际值
# ─────────────────────────────────────────────────────────

# 运行环境（生产环境填 production）
NODE_ENV=production

# 服务端口（cPanel Passenger 会自动覆盖此值，无需修改）
PORT=3000

# Session 密钥 — 必须修改为随机长字符串（至少32位）
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=请替换为随机字符串至少32位

# bcrypt 加密强度（生产环境建议12，值越大越慢越安全）
BCRYPT_COST=12

# ─── SMTP 邮件配置（可选，不填则邮件功能降级为日志输出）────
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_smtp_password
SMTP_FROM=升学系统 <noreply@yourdomain.com>

# ─── OpenAI API（可选，不填则 AI 功能不可用）──────────────
OPENAI_API_KEY=sk-...
